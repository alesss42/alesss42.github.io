  author = {Pinkel, Robert and Munk, Walter and Worcester, Peter and Comuelle, Bruce D. and Rudnick, Daniel and Sherman, Jeffrey and Filloux, Jean H. and Dushaw, Brian D. and Howe, Bruce M. and Sanford, Thomas B. and Lee, Craig M. and Kunze, Eric and Gregg, Michael C. and Miller, Jack B. and Merrifield, Mark A. and Luther, Douglas S. and Firing, Eric and Brainard, Rusty and Flament, Pierre J. and Chave, Alan D. and Moum, James M. and Caldwell, Douglas R. and Levine, Murray D. and Boyd, Timothy and Egbert, Gary D.},
  year = 2000,
  journal = {Eos, Transactions American Geophysical Union},
