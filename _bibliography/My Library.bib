  title = {Computational {{Ocean Acoustics}}},
  author = {Jensen, Finn B. and Kuperman, William A. and Porter, Michael B. and Schmidt, Henrik},
  year = 2011,
  series = {Modern {{Acoustics}} and {{Signal Processing}}},
  publisher = {Springer},
