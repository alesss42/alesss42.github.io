@article{leboyerTurbulentDiapycnal2023,
  title = {Turbulent Diapycnal Fluxes as a Pilot {{Essential Ocean Variable}}},
  author = {Le Boyer, Arnaud and Couto, Nicole and Alford, Matthew H. and Drake, Henri F. and Bluteau, Cynthia E. and Hughes, Kenneth G. and Naveira Garabato, Alberto C. and Moulin, Aur{\'e}lie J. and Peacock, Thomas and Fine, Elizabeth C. and Mashayek, Ali and Cimoli, Laura and Meredith, Michael P. and Melet, Angelique and Fer, Ilker and Dengler, Marcus and Stevens, Craig L.},
  year = 2023,
  month = nov,
  journal = {Frontiers in Marine Science},
  volume = {10},
  publisher = {Frontiers},
  issn = {2296-7745},
  doi = {10.3389/fmars.2023.1241023},
  urldate = {2025-02-19},
  abstract = {{$<$}p{$>$}We contend that ocean turbulent fluxes should be included in the list of Essential Ocean Variables (EOVs) created by the Global Ocean Observing System. This list aims to identify variables that are essential to observe to inform policy and maintain a healthy and resilient ocean. Diapycnal turbulent fluxes quantify the rates of exchange of tracers (such as temperature, salinity, density or nutrients, all of which are already EOVs) across a density layer. Measuring them is necessary to close the tracer concentration budgets of these quantities. Measuring turbulent fluxes of buoyancy ({$<$}italic{$>$}J\textsubscript{b}{$<$}/italic{$>$}), heat ({$<$}italic{$>$}J\textsubscript{q}{$<$}/italic{$>$}), salinity ({$<$}italic{$>$}J\textsubscript{S}{$<$}/italic{$>$}) or any other tracer requires either synchronous microscale (a few centimeters) measurements of both the vector velocity and the scalar (e.g., temperature) to produce time series of the highly correlated perturbations of the two variables, or microscale measurements of turbulent dissipation rates of kinetic energy ({$<$}italic{$>\epsilon<$}/italic{$>$}) and of thermal/salinity/tracer variance ({$<$}italic{$>\chi<$}/italic{$>$}), from which fluxes can be derived. Unlike isopycnal turbulent fluxes, which are dominated by the mesoscale (tens of kilometers), microscale diapycnal fluxes cannot be derived as the product of existing EOVs, but rather require observations at the appropriate scales. The instrumentation, standardization of measurement practices, and data coordination of turbulence observations have advanced greatly in the past decade and are becoming increasingly robust. With more routine measurements, we can begin to unravel the relationships between physical mixing processes and ecosystem health. In addition to laying out the scientific relevance of the turbulent diapycnal fluxes, this review also compiles the current developments steering the community toward such routine measurements, strengthening the case for registering the turbulent diapycnal fluxes as an pilot Essential Ocean Variable.{$<$}/p{$>$}},
  langid = {english},
  keywords = {Dissipation rate,EOV,GOOS,Mixing efficiency,ocean turbulence,Turbulent diffusivity,turbulent dissipation,Turbulent fluxes},
  file = {/Users/alesan/Zotero/storage/3ERYTXH6/Le Boyer et al. - 2023 - Turbulent diapycnal fluxes as a pilot Essential Oc.pdf}
}

