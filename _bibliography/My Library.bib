@article{sarkarInterplaySubmesoscale2016,
  title = {The {{Interplay Between Submesoscale Instabilities}} and {{Turbulence}} in the {{Surface Layer}} of the {{Bay}} of {{Bengal}}},
  author = {Sarkar, Sutanu and Pham, Hieu T. and Ramachandran, Sanjiv and Nash, Jonathan D. and Tandon, Amit and Buckley, Jared and Lotliker, Aneesh A. and Omand, Melissa M.},
