  issn = {1042-8275},
  urldate = {2023-09-24},
  abstract = {ABSTRACTThe Air-Sea Interactions Regional Initiative (ASIRI) aims to understand vertical fluxes of momentum and heat across the surface layer in the Bay of Bengal. As the mesoscale and submesoscale eddies redistribute freshwater input over saline water of the bay, they influence the vertical distribution of salinity and thus impact air-sea fluxes. This study reports on numerical simulations performed to investigate processes that can lead to the observed vertical structure of stratification near the ocean surface. Processes are explored at multiple lateral scales, ranging from a few meters to tens of kilometers, to elucidate how the interplay among large-scale motion, submesoscale instabilities, and small-scale turbulent motion affects the surface layer.},
