@article{ijichiObservedVariations2018,
  title = {Observed {{Variations}} in {{Turbulent Mixing Efficiency}} in the {{Deep Ocean}}},
  author = {Ijichi, Takashi and Hibiya, Toshiyuki},
  year = 2018,
  month = aug,
  journal = {Journal of Physical Oceanography},
  volume = {48},
  number = {8},
  pages = {1815--1830},
  publisher = {American Meteorological Society},
  issn = {0022-3670, 1520-0485},
  doi = {10.1175/JPO-D-17-0275.1},
  urldate = {2023-09-07},
  abstract = {Abstract Recent progress in direct numerical simulations (DNSs) of stratified turbulent flows has led to increasing attention to the validity of the constancy of the dissipation flux coefficient {$\Gamma$} in the Osborn's eddy diffusivity model. Motivated by lack of observational estimates of {$\Gamma$}, particularly under weakly stratified deep-ocean conditions, this study estimates {$\Gamma$} using deep microstructure profiles collected in various regions of the North Pacific and Southern Oceans. It is shown that {$\Gamma$} is not constant but varies significantly with the Ozmidov/Thorpe scale ratio ROT in a fashion similar to that obtained by previous DNS studies. Efficient mixing events with {$\Gamma$} \textasciitilde{} O(1) and ROT \textasciitilde{} O(0.1) tend to be frequently observed in the deep ocean (i.e., weak stratification), while moderate mixing events with {$\Gamma$} \textasciitilde{} O(0.1) and ROT \textasciitilde{} O(1) tend to be observed in the upper ocean (i.e., strong stratification). The observed negative relationship between {$\Gamma$} and ROT is consistent with a simple scaling that can be derived from classical turbulence theories. In contrast, the observed results exhibit no definite relationships between {$\Gamma$} and the buoyancy Reynolds number Reb, although Reb has long been thought to be another key parameter that controls {$\Gamma$}.},
  chapter = {Journal of Physical Oceanography},
  langid = {english},
  file = {/Users/alesan/Documents/RESEARCH/Literature_Review/Ijichi_Hibiya_2018_Observed Variations in Turbulent Mixing Efficiency in the Deep Ocean.pdf}
}

