  langid = {english},
  keywords = {INVESTIGATE},
  file = {/Users/alesan/Zotero/storage/6XVY39HT/Middleton and Thomson - 1985 - Steady Wind-Driven Coastal Circulation on a β-Plan.pdf;/Users/alesan/Zotero/storage/PIPXQ5G6/1520-0485_1985_015_1809_swdcco_2_0_co_2.html}
