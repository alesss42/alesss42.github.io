@article{ruddickOceanicThermohalineIntrusions2003,
  title = {Oceanic Thermohaline Intrusions: Observations},
  shorttitle = {Oceanic Thermohaline Intrusions},
  author = {Ruddick, B. and Richards, K.},
  year = 2003,
  month = mar,
