@article{jutrasMixingAccounts,
  title = {Mixing Accounts for More than Half of Biogeochemical Changes along {{Mode Water}} Ventilation Pathways},
  author = {Jutras, Mathilde and Bushinsky, Seth M. and Cerovecki, Ivana and Briggs, Nathan},
