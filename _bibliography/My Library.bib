  pages = {499--527},
  issn = {0079-6611},
  doi = {10.1016/S0079-6611(03)00028-4},
  urldate = {2023-05-29},
  abstract = {Intrusions are commonly observed in the upper, deep and coastal oceans, and are closely linked to lateral fluxes of heat, salt and momentum. This is a review of observations of intrusions and the results of comparisons of properties such as scale, slopes, microstructure activity, and fluxes with theoretical models. A summary of estimates of lateral heat fluxes indicates a wide range of lateral diffusivities. We conclude by noting that our present knowledge is insufficient to predict the structure, length-scales and lateral fluxes of thermohaline intrusions with confidence, and list a number of unresolved questions. Suggestions are made for compilation of existing data into a database for exploratory analysis and testing of theoretical hypotheses. An outline is given of a potential collaborative field experiment using CTD, fluorescent dye, and microstructure observations.},
  langid = {english},
  file = {/Users/alesan/Zotero/storage/X2PXJAU4/S0079661103000284.html}
}

@article{ruddickVariationsApparent1997,
  title = {Variations in {{Apparent Mixing Efficiency}} in the {{North Atlantic Central Water}}},
  author = {Ruddick, Barry and Walsh, David and Oakey, Neil},
  year = 1997,
  month = dec,
  journal = {Journal of Physical Oceanography},
  volume = {27},
  number = {12},
  pages = {2589--2605},
  publisher = {American Meteorological Society},
  issn = {0022-3670, 1520-0485},
  doi = {10.1175/1520-0485(1997)027<2589:VIAMEI>2.0.CO;2},
  urldate = {2023-06-19},
  abstract = {Abstract Microstructure data from the North Atlantic Tracer Release Experiment (NATRE) are presented, providing detailed profiles of the thermal variance {$\chi$} in the upper 360 m of the Canary Basin for the fall and spring seasons. The Osborn--Cox model is used to compute the diffusivity KT. The diffusivity for the depth range 240--340 m is found to be 1.0(\textpm 0.04) \texttimes{} 10-5 m2 s-1 in the fall and 2.2(\textpm 0.1) \texttimes{} 10-5 m2 s-1 in the spring, in good agreement with dye-inferred diffusivities at similar depths. Measured turbulent kinetic energy (TKE) dissipation rates were found to be contaminated by hydrodynamic noise, so the Osborn dissipation method was not used to compute K{$\rho$}. However, data segments for which the TKE dissipation rate ({$\varepsilon$}) was large enough to be unaffected by noise were used to compute the ``apparent mixing efficiency'' {$\Gamma$}d. The computed {$\Gamma$}d values are used to investigate variations in apparent mixing efficiency with respect to density ratio (R{$\rho$}) and turbulence Reynolds number [{$\varepsilon$}/({$\nu$}N2)], in an attempt to elucidate the underlying mechanisms of mixing in the NATRE region. Observed variations of {$\Gamma$}d are compared with existing theoretical models of mixing due to: salt fingers, a combination of salt fingers and turbulence, ``conventional'' high Reynolds number turbulence, and low Reynolds number buoyancy-modified turbulence. Significant variations of {$\Gamma$}d with respect to both R{$\rho$} and {$\varepsilon$}/({$\nu$}N2) are found. Although Monte Carlo tests show that some of the observed variations could be noise-induced, a substantial portion of the systematic variations the authors observed were not reproduced by Monte Carlo simulations. These trends are found to be statistically significant, and the authors conclude that they represent real variations in the apparent mixing efficiency. The authors find that {$\Gamma$}d is an increasing function of {$\varepsilon$}/({$\nu$}N2) and a decreasing function of R{$\rho$}; these variations are not fully consistent with any of the available mixing models.},
  chapter = {Journal of Physical Oceanography},
  langid = {english},
  file = {/Users/alesan/Documents/RESEARCH/Literature_Review/Ruddick et al_1997_Variations in Apparent Mixing Efficiency in the North Atlantic Central Water.pdf}
}

