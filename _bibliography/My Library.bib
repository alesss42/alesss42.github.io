@article{st.laurentMeasurementsNearSurface2017,
  title = {Measurements of {{Near-Surface Turbulence}} and {{Mixing}} from {{Autonomous Ocean Gliders}}},
  author = {St. Laurent, Louis and Merrifield, Sophia},
  year = 2017,
  journal = {Oceanography},
  volume = {30},
  number = {2},
  eprint = {26201858},
  eprinttype = {jstor},
  pages = {116--125},
  publisher = {Oceanography Society},
  issn = {1042-8275},
  urldate = {2025-04-11},
  abstract = {ABSTRACT. As autonomous sampling technologies have matured, ocean sensing concepts with long histories have migrated from their traditional ship-based roots to new platforms. Here, we discuss the case of ocean microstructure sensing, which provides the basis for direct measurement of small-scale turbulence processes that lead to mixing and buoyancy flux. Due to their hydrodynamic design, gliders are an optimal platform for microstructure sensing. A buoyancy-driven glider can profile through the ocean with minimal vibrational noise, a common limitation of turbulence measurements from other platforms. Moreover, gliders collect uncontaminated data during both descents and ascents, permitting collection of near-surface measurements unattainable from ship-based sensing. Persistence and the capability to sample in sea states not feasible for deck-based operations make glider-based microstructure sampling a profoundly valuable innovation. Data from two recent studies illustrate the novel aspects of glider-based turbulence sensing. Surface stable layers, characteristic of conditions with incoming solar radiation and weak winds, exemplify a phenomenon not easily sampled with ship-based methods. In the North Atlantic, dissipation rate measurements in these layers revealed unexpected turbulent mixing during times of peak warming, when enhanced stratification in a thin layer led to an internal wave mode that received energy from the deeper internal wave field of the thermocline. Hundreds of profiles were obtained in the Bay of Bengal through a barrier layer that separates a strongly turbulent surface layer from a surprisingly quiescent interior just 20 m below. These studies demonstrate the utility of buoyancy-driven gliders for collecting oceanic turbulence measurements.},
  file = {/Users/alesan/Documents/RESEARCH/Literature_Review/St. Laurent_Merrifield_2017_Measurements of Near-Surface Turbulence and Mixing from Autonomous Ocean Gliders.pdf}
}

@article{stammerEddyCharacteristics1998,
  title = {On {{Eddy Characteristics}}, {{Eddy Transports}}, and {{Mean Flow Properties}}},
  author = {Stammer, Detlef},
  year = 1998,
  month = apr,
  issn = {1520-0485},
  urldate = {2025-02-09},
  abstract = {Estimates of eddy energy and eddy scales obtained previously from TOPEX/POSEIDON (T/P) altimeter data are interpreted in the context of a baroclinically unstable flow field. From the observations an integral timescale Talt can be defined that---combined with estimates of the eddy kinetic energy---sets a mixing length scale. Results are compared with theories of a baroclinically unstable flow field. For such conditions, the Eady theory predicts a timescale Tbc = Ri/f from the mean-flow Richardson number Ri, which shows some qualitative agreement with T/P results in terms of a geographical distribution. A factor of 2 difference between the timescales can be explained in terms of a systematic difference between the specific definitions of scale estimates. Although transfer length and velocity scales emerging out of scaling arguments lack resemblance with observations, a transfer length scale based on Tbc and the observed eddy kinetic energy is strikingly consistent with observed eddy scales. Primarily independent of the energetic state of the ocean, they are to first order largest in low latitudes and decrease toward high latitudes. Invoking a ``mixing length'' hypothesis, an eddy transfer {$\kappa$} for a scalar tracer in the ocean can be estimated from eddy statistics as a function of geographical position. Two different estimates of {$\kappa$} can be obtained from altimetric data: (i) {$\kappa$} = {$\alpha$}KELbc and (ii) κ̃ = {$\alpha\prime$}(g/f){$\sigma$}(SSH), where {$\alpha$} and {$\alpha\prime$} are scaling factors, and {$\sigma$}({$\zeta$}) is the rms sea-surface height variability estimated from T/P data. The approaches lead to similar estimates of a meridional eddy-induced heat and salt flux inferred from climatological meridional temperature and salinity gradient FT = -cp{$\kappa\partial$}T/{$\partial$}y and FS = -{$\kappa\partial$}S/{$\partial$}y. Results are consistent with previous knowledge but, because estimates are based on mean meridional gradients, they have to be considered a lower bound on instantaneous eddy transports in the ocean.},
  chapter = {Journal of Physical Oceanography},
  langid = {english},
  file = {/Users/alesan/Documents/RESEARCH/Literature_Review/Stammer_1998_On Eddy Characteristics, Eddy Transports, and Mean Flow Properties.pdf}
}

@article{stammerEddyCharacteristicsEddy1998,
  title = {On {{Eddy Characteristics}}, {{Eddy Transports}}, and {{Mean Flow Properties}}},
  author = {Stammer, Detlef},
  year = 1998,
  month = apr,
  journal = {Journal of Physical Oceanography},
  volume = {28},
  number = {4},
  pages = {727--739},
  issn = {0022-3670},
  doi = {10.1175/1520-0485(1998)028<0727:OECETA>2.0.CO;2},
  urldate = {2014-12-09},
  abstract = {Abstract Estimates of eddy energy and eddy scales obtained previously from TOPEX/POSEIDON (T/P) altimeter data are interpreted in the context of a baroclinically unstable flow field. From the observations an integral timescale Talt can be defined that---combined with estimates of the eddy kinetic energy---sets a mixing length scale. Results are compared with theories of a baroclinically unstable flow field. For such conditions, the Eady theory predicts a timescale Tbc = (Ri){$\frac{1}{2}$}/f from the mean-flow Richardson number Ri, which shows some qualitative agreement with T/P results in terms of a geographical distribution. A factor of 2 difference between the timescales can be explained in terms of a systematic difference between the specific definitions of scale estimates. Although transfer length and velocity scales emerging out of scaling arguments lack resemblance with observations, a transfer length scale based on Tbc and the observed eddy kinetic energy is strikingly consistent with observed eddy scales. Primarily independent of the energetic state of the ocean, they are to first order largest in low latitudes and decrease toward high latitudes. Invoking a ``mixing length'' hypothesis, an eddy transfer {$\kappa$} for a scalar tracer in the ocean can be estimated from eddy statistics as a function of geographical position. Two different estimates of {$\kappa$} can be obtained from altimetric data: (i) {$\kappa$} = {$\alpha$}(KE){$\frac{1}{2}$}Lbc and (ii) κ̃ = {$\alpha\prime$}(g/f){$\sigma$}(SSH), where {$\alpha$} and {$\alpha\prime$} are scaling factors, and {$\sigma$}({$\zeta$}) is the rms sea-surface height variability estimated from T/P data. The approaches lead to similar estimates of a meridional eddy-induced heat and salt flux inferred from climatological meridional temperature and salinity gradient FT = -cp{$\kappa\partial$}T/{$\partial$}y and FS = -{$\kappa\partial$}S/{$\partial$}y. Results are consistent with previous knowledge but, because estimates are based on mean meridional gradients, they have to be considered a lower bound on instantaneous eddy transports in the ocean.}
}

